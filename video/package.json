{
  "name": "agentic-starter-skills-video",
  "version": "1.0.0",
  "description": "Vídeo explicativo (Remotion) sobre as skills do agentic-starter",
  "private": true,
  "scripts": {
    "start": "remotion studio",
    "build": "remotion render SkillsTutorialPT assets/skills-tutorial.mp4",
    "build:en": "remotion render SkillsTutorialEN assets/skills-tutorial-en.mp4",
    "build:all": "npm run build && npm run build:en",
    "build:why": "remotion render WhyAgenticStarterPT assets/why-agentic-starter.mp4",
    "build:why:en": "remotion render WhyAgenticStarterEN assets/why-agentic-starter-en.mp4",
    "build:why:all": "npm run build:why && npm run build:why:en",
    "still": "remotion still SkillsTutorialPT assets/cover.png --frame=110",
    "still:en": "remotion still SkillsTutorialEN assets/cover-en.png --frame=110",
    "still:why": "remotion still WhyAgenticStarterPT assets/why-cover.png --frame=85",
    "still:why:en": "remotion still WhyAgenticStarterEN assets/why-cover-en.png --frame=85",
    "regression": "node scripts/regression.mjs"
  },
  "dependencies": {
    "@remotion/cli": "4.0.250",
    "@remotion/shapes": "4.0.250",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "remotion": "4.0.250"
  },
  "devDependencies": {
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "typescript": "5.5.4"
  }
}
